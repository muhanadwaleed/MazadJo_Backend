# --- Django core ---
# Generate a strong key for production: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-in-production
DEBUG=True
# Comma-separated hostnames
ALLOWED_HOSTS=localhost,127.0.0.1
LANGUAGE_CODE=en-us
TIME_ZONE=UTC

# --- Database ---
# Option A — SQLite (default): leave POSTGRES_DB and DATABASE_URL empty
SQLITE_PATH=db.sqlite3

# Option B — PostgreSQL via discrete vars (used when POSTGRES_DB is non-empty)
POSTGRES_DB=
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

# Option C — Full URL (highest precedence: when set, POSTGRES_* and SQLite defaults below are ignored)
# Examples:
#   postgres://USER:PASSWORD@HOST:PORT/DBNAME
#   postgresql://USER:PASSWORD@HOST:PORT/DBNAME
#   sqlite:///absolute/path/db.sqlite3
DATABASE_URL=

# --- Redis (Channels + Celery) ---
# WebSocket channel layer: Redis when set, otherwise in-memory (dev only).
REDIS_URL=
# Examples:
# REDIS_URL=redis://127.0.0.1:6379/0

# Celery defaults to Redis DB 1 derived from REDIS_URL, or set explicitly:
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TIMEZONE=UTC
# Run tasks synchronously (no worker) — default True when REDIS_URL and CELERY_BROKER_URL are both unset
CELERY_TASK_ALWAYS_EAGER=
CELERY_TASK_EAGER_PROPAGATES=True

# --- HTTP / reverse proxy (production) ---
USE_X_FORWARDED_HOST=False
# Comma-separated origins, e.g. https://app.example.com,https://www.example.com
CSRF_TRUSTED_ORIGINS=
# When behind TLS-terminating proxy: header name and value, comma-separated
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https

# --- Static & media ---
STATIC_URL=static/
STATIC_ROOT=staticfiles
MEDIA_URL=media/
MEDIA_ROOT=media

# --- Email (OTP, notifications) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For SMTP, e.g. django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=webmaster@localhost

# --- Logging ---
DJANGO_LOG_LEVEL=INFO

# --- Observability (Sentry + Prometheus) ---
# Error tracing and performance (leave empty to disable)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
# Expose /metrics/ for Prometheus (403 when disabled)
ENABLE_PROMETHEUS_METRICS=False
# Optional: require X-Metrics-Token: <value> on GET /metrics/
METRICS_SCRAPE_TOKEN=

# --- Bidding abuse controls ---
# Per-user per-auction bid attempts per wall-clock second (cache-backed)
BID_MAX_PER_SECOND_PER_USER=3
AUCTION_MEDIA_MAX_BYTES=10485760
# DB velocity window used by fraud helpers (seconds)
BID_VELOCITY_WINDOW_SEC=1

# --- Fraud / risk scoring (defaults: score only; enforcement off) ---
RISK_SCORE_MAX=100
RISK_SHADOW_BAN_SCORE=50
RISK_HARD_BAN_SCORE=80
# When True, bids blocked if UserRiskScore.score >= RISK_SHADOW_BAN_SCORE (still respects staff User.is_shadow_banned)
RISK_ENFORCE_SHADOW_FROM_SCORE=False
# When True, Celery may set user.is_active=False at hard threshold (use with care)
RISK_ENFORCE_HARD_DEACTIVATE=False
# Points added when cache bid rate limit trips (0 = disabled)
RISK_RATE_LIMIT_CACHE_BUMP=0
# Points when user extends a chain of consecutive own bids (0 = disabled)
RISK_SELF_OUTBID_BUMP=0
RISK_SELF_OUTBID_MIN_PRIOR_RUN=2
RISK_PUMPING_BUMP=20
RISK_SHARED_IP_ACCOUNT_THRESHOLD=3
RISK_SHARED_IP_BUMP=30
RISK_WIN_RATIO_MIN_TOTAL_BIDS=10
RISK_WIN_RATIO_THRESHOLD=0.8
RISK_WIN_RATIO_BUMP=15
FRAUD_ANALYZE_BID_ASYNC=True

# Fingerprint middleware: sampled (not every request); off by default
FINGERPRINT_MIDDLEWARE_ENABLED=False
FINGERPRINT_MIN_INTERVAL_SECONDS=3600

# Shadow bids: silent (hidden / no price) vs hard reject (403-style)
SHADOW_BID_SILENT_PUBLICATION=True
RISK_PUMPING_WINDOW_SECONDS=15
RISK_STATS_FALLBACK_WHEN_ZERO=True
RISK_DECAY_ENABLED=True
RISK_DECAY_MODE=linear
RISK_DECAY_LINEAR_POINTS=1
RISK_DECAY_MULTIPLY_FACTOR=0.95

# --- CORS (browser clients) ---
# Comma-separated origins, e.g. http://localhost:3000,http://localhost:3001,https://app.example.com
CORS_ALLOWED_ORIGINS=
# When CORS_ALLOWED_ORIGINS is empty: allow all origins only if DEBUG (not for production)
CORS_ALLOW_ALL_ORIGINS=
CORS_ALLOW_CREDENTIALS=True

# --- Payment webhooks (generic HMAC provider) ---
# Raw body HMAC-SHA256 hex, header: X-Webhook-Signature: sha256=<hex>
WEBHOOK_PAYMENT_SECRET=

# --- JWT (djangorestframework-simplejwt) ---
# POST /api/auth/token/ with {"username":"...","password":"..."} -> access + refresh
# Use header: Authorization: Bearer <access>
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7
# If True, add "rest_framework_simplejwt.token_blacklist" to INSTALLED_APPS and migrate
JWT_ROTATE_REFRESH_TOKENS=False
JWT_BLACKLIST_AFTER_ROTATION=False
JWT_ALGORITHM=HS256
# Optional separate signing key; defaults to SECRET_KEY
JWT_SIGNING_KEY=
JWT_AUTH_HEADER_TYPE=Bearer
JWT_AUTH_HEADER_NAME=HTTP_AUTHORIZATION

# --- SMS OTP (accounts.tasks.dispatch_otp_delivery — hash-only in DB, no plain in broker) ---
SMS_GATEWAY_URL=
SMS_GATEWAY_API_KEY=
SMS_FORM_FIELD_TO=to
SMS_FORM_FIELD_MESSAGE=message
SMS_HTTP_TIMEOUT=5
OTP_TTL_MINUTES=10
REGISTRATION_OTP_MAX_AGE_MINUTES=30
OTP_RATE_LIMIT_MAX=3
OTP_RATE_LIMIT_WINDOW_MINUTES=10
FIXED_OTP=False

# Last N seconds of auction always extend (even if extension_trigger_seconds is large)
ANTI_SNIPE_FORCE_SECONDS=10

# --- Celery beat (django-celery-beat) ---
# After migrate: python manage.py seed_celery_beat
# Run worker + beat: celery -A core worker -l info  AND  celery -A core beat -l info

# FCM_SERVER_KEY=

# --- Optional production hardening (uncomment and tune behind HTTPS) ---
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
