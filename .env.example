# MazadJo — environment template (Phases 0–2: bootstrap, identity, catalog)
# Copy: cp .env.example .env
# Later phases (listings, lifecycle, payments, bidding, …) add vars here as you ship them.

# --- Django core ---
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
LANGUAGE_CODE=en-us
TIME_ZONE=UTC

# --- Database (Phase 2 seed_catalog + migrations) ---
# Default: SQLite when POSTGRES_DB and DATABASE_URL are empty
SQLITE_PATH=db.sqlite3
POSTGRES_DB=
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60
# DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DBNAME

# --- CORS (web app → API; Phase 0 / Phase 1) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOW_CREDENTIALS=True

# --- JWT (Phase 1 — login, refresh, protected routes) ---
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=False
JWT_BLACKLIST_AFTER_ROTATION=False
JWT_ALGORITHM=HS256
JWT_SIGNING_KEY=
JWT_AUTH_HEADER_TYPE=Bearer
JWT_AUTH_HEADER_NAME=HTTP_AUTHORIZATION

# --- Email (Phase 1 — verify_email OTP when not using SMS) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=webmaster@localhost

# --- SMS OTP (Phase 1 — register / verify / password reset) ---
SMS_GATEWAY_URL=
SMS_GATEWAY_API_KEY=
SMS_FORM_FIELD_TO=to
SMS_FORM_FIELD_MESSAGE=message
SMS_HTTP_TIMEOUT=5
OTP_TTL_MINUTES=10
REGISTRATION_OTP_MAX_AGE_MINUTES=30
OTP_RATE_LIMIT_MAX=3
OTP_RATE_LIMIT_WINDOW_MINUTES=10
# Local dev: True → OTP is always 1111 (no real SMS)
FIXED_OTP=True

# --- Redis / Celery (optional locally; required for multi-process workers + WebSocket) ---
# Leave REDIS_URL empty for SQLite + in-memory Celery (OTP runs eagerly in-process).
REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=
CELERY_TASK_EAGER_PROPAGATES=True

# --- Logging ---
DJANGO_LOG_LEVEL=INFO
